# ─── Local configs with OSS credentials ───────────────────────────────
# Copy config-example.yaml to config.yaml and fill in your credentials.
# The config.yaml files are gitignored so secrets are never committed.
**/config.yaml
**/style.yaml  # Legacy naming (deprecated)

# ─── Output HTML files ───────────────────────────────────────────────
**/output/*.html

# ─── Python artifacts ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/

# ─── macOS ───────────────────────────────────────────────────────────
.DS_Store

